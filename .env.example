# ============================================================================
# BRAINLEX — Variables de entorno
#
# Copia este archivo a .env.local y completa los valores.
# NUNCA commitees .env.local ni credenciales reales.
# ============================================================================

# ─── Base de Datos (Supabase / PostgreSQL) ──────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/brainlex"

# ─── Sociedades Matriz (CIFs separados por coma) ───────────────────────────
BRAINLEX_MATRIZ_CIFS=B12345678,A98765432

# ─── Google Maps (solo frontend — Places Autocomplete) ─────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ─── Google Drive API (Service Account) ────────────────────────────────────
#
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON:
#   JSON completo del Service Account de Google Cloud.
#   Obtener desde: Google Cloud Console > IAM > Service Accounts > Keys > JSON
#   Pegar el JSON completo en UNA SOLA LÍNEA (sin saltos de línea).
#   Permisos requeridos: Google Drive API (drive scope)
#
# GOOGLE_DRIVE_ROOT_FOLDER_ID:
#   ID de la carpeta raíz en Google Drive donde BRAINLEX creará la estructura.
#   Obtener desde la URL de Drive: https://drive.google.com/drive/folders/{ID}
#   La Service Account debe tener acceso de escritura a esta carpeta.
#
# Si estas variables NO están configuradas, la Bóveda funciona en modo
# simulación (solo BD, sin crear carpetas reales en Drive).
#
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=""
GOOGLE_DRIVE_ROOT_FOLDER_ID=""
