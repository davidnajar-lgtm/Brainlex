// ============================================================================
// schema.prisma — Brainlex / Lawork ERP
// Micro-Spec 1.1: Esquema Core y Multi-tenancy Híbrida
//
// Roles aplicados:
//   @Data-Architect  → modelo de Entidades único, lógica multitenant dinámica
//   @Security-CISO   → ciclo de vida Cuarentena, AuditLog inmutable
//
// VETO LEGAL (@security_and_legal.md):
//   NUNCA DELETE directo sobre un Contacto con historial comercial o legal.
//   Usar el flujo de Cuarentena: Auditoría → Bloqueo → Caducidad.
//
// REGLA DE VETO DE MIGRACIÓN:
//   Este archivo NO puede ejecutarse contra la BD hasta que el
//   Arquitecto Jefe dé autorización explícita.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

/// Tipo de contacto fiscal (persona física o jurídica).
enum ContactoTipo {
  PERSONA_FISICA
  PERSONA_JURIDICA
}

/// Ciclo de vida del Contacto — VETO LEGAL: no existe transición directa a DELETE.
///   ACTIVE     → registro operativo normal
///   QUARANTINE → baja lógica con retención legal (quarantine_reason OBLIGATORIO)
///   FORGOTTEN  → crypto-shredding GDPR: PII eliminado, NIF/Razón Social conservados
///                por obligación tributaria (art. 30 CComercio, Ley 58/2003 GILF)
enum ContactoStatus {
  ACTIVE
  QUARANTINE
  FORGOTTEN
}

/// Tipos de identificación fiscal aceptados.
enum FiscalIdTipo {
  NIF
  CIF
  NIE
  DNI
  PASAPORTE
  VAT
  TIE
  K   /// NIF K — español menor de 14 años residente en España (provisional hasta DNI)
  L   /// NIF L — español residente en el extranjero (provisional hasta DNI)
  M   /// NIF M — extranjero sin NIE con intereses económicos en España (provisional hasta NIE)
  REGISTRO_EXTRANJERO
  CODIGO_SOPORTE
  SIN_REGISTRO
}

/// Scope de visibilidad de una Etiqueta — @Scope-Guard
///   GLOBAL    → visible para todos los tenants
///   LEXCONOMY → solo visible para LX
///   LAWTECH   → solo visible para LW
enum EtiquetaScope {
  GLOBAL
  LEXCONOMY
  LAWTECH
}

/// Tipo de carpeta en la Bóveda documental del contacto.
///   INTELIGENTE → generada automáticamente desde Etiqueta Constructor (Servicio/Departamento)
///   MANUAL      → creada libremente por el usuario (huérfana de etiqueta)
enum CarpetaTipo {
  INTELIGENTE
  MANUAL
}

/// Acciones registradas en el AuditLog inmutable.
enum AuditAction {
  CREATE
  READ
  UPDATE
  QUARANTINE
  RESTORE
  FORGET
}

// ============================================================================
// SociedadHolding  ←  TABLA MAESTRA DEL HOLDING
//
// Cada fila representa una empresa del grupo.
// Escalabilidad REAL: añadir "Empresa C" = un INSERT en esta tabla.
// Sin tocar el esquema, sin migraciones de tipo, sin enum que evolucionar.
//
// company_id es una clave de tenant dinámica (String). Ejemplos: "LX", "LW", "LC".
// ============================================================================
model SociedadHolding {
  id          String  @id @default(cuid())
  company_id  String  @unique /// Clave de tenant dinámica: "LX", "LW", "LC"
  nombre      String
  nif         String?
  descripcion String?
  activa      Boolean @default(true)

  /// Meses de retención en cuarentena para esta Sociedad.
  /// Por defecto: 60 meses (5 años — art. 70 Ley 58/2003 GILF + prescripción mercantil).
  /// Editable por el Administrador. Mínimo legal recomendado: 36 meses.
  quarantine_months Int @default(60)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relaciones descendentes
  contacto_links ContactoCompanyLink[]
  expedientes    Expediente[]

  @@map("sociedades_holding")
}

// ============================================================================
// Contacto  ←  TABLA GLOBAL (deliberadamente sin company_id)
//
// Unifica Contactos y Clientes para evitar duplicidades entre LX y LW.
// Un mismo contacto puede tener actividad en LX, en LW, o en ambas.
//
// La vinculación empresa ↔ contacto se gestiona mediante ContactoCompanyLink.
// El company_id vive en la tabla puente, NO aquí.
// ============================================================================
model Contacto {
  id   String       @id @default(cuid())
  tipo ContactoTipo @default(PERSONA_FISICA)

  // — Persona Física —
  nombre    String?
  apellido1 String?
  apellido2 String?

  // — Persona Jurídica —
  razon_social  String?
  tipo_sociedad String? /// S.L., S.A., S.L.U., etc. — requerido si tipo = PERSONA_JURIDICA

  // — Identificación Fiscal —
  fiscal_id      String?
  fiscal_id_tipo FiscalIdTipo?

  // — Canales de Comunicación Directos —
  email_principal String?           /// Email principal — NO único: persona física y su sociedad pueden compartir email
  telefono_movil  String?           /// Número E.164 de teléfono móvil
  telefono_fijo   String?           /// Número E.164 de teléfono fijo/central
  website_url     String?           /// URL del sitio web oficial (normalizada a https://)
  linkedin_url    String?           /// URL del perfil de LinkedIn
  canal_preferido String   @default("EMAIL") /// Canal oficial: "EMAIL" | "MOVIL"

  // — Roles (no excluyentes) —
  es_cliente        Boolean @default(false)
  es_precliente     Boolean @default(false) /// Contacto en fase de conversión a cliente (pipeline comercial).
  es_contacto       Boolean @default(true)
  es_facturadora    Boolean @default(false) /// Entidad matriz de facturación (Lexconomy/Lawtech). Veto de borrado permanente.
  es_entidad_activa Boolean @default(false) /// Entidad holding activa protegida. Veto de borrado permanente.

  // — Ciclo de vida (VETO LEGAL) ————————————————————————————————————————————
  // REGLA: si status = QUARANTINE → quarantine_reason OBLIGATORIO
  //        La capa de servicio lanza 403 si se intenta DELETE con historial.
  //        Si status = FORGOTTEN  → PII borrado, pero NIF/razon_social intactos.
  status                ContactoStatus @default(ACTIVE)
  quarantine_reason     String?   /// Requerido cuando status = QUARANTINE
  quarantine_expires_at DateTime? /// Plazo asignado por Agente Legal
  forgotten_at          DateTime? /// Timestamp del crypto-shredding GDPR

  // — Campos Fiscales Avanzados (Micro-Spec 2.1) ——————————————————————————————
  // Solo editables por rol Admin / gestor fiscal autorizado.
  // prorrata_pct: ZONA VEDADA — no tocar sin CTO + revisión legal (@ARCHITECTURE_RULES #1)
  cnae               String?  /// Código Nacional de Actividades Económicas
  iae                String?  /// Epígrafe del Impuesto de Actividades Económicas
  prorrata_pct       Int?     /// % de prorrata IVA (0–100). ZONA VEDADA: no modificar sin CTO
  hacienda_status    String?  /// Estado censal AEAT (Alta/Baja/en trámite + fecha comprobación)
  last_accounts_year Int?     /// Último año de cuentas anuales presentadas en el Registro
  last_books_year    Int?     /// Último año de libros contables cerrados formalmente

  // — Estado comercial (INDEPENDIENTE del ciclo legal QUARANTINE/FORGOTTEN) —
  // true  = contacto operativo visible en el Directorio activo
  // false = oculto del Directorio pero datos íntegros; sin restricción legal
  is_active Boolean @default(true)

  // — Notas libres —
  notas String?

  // — Metadatos extendidos (JSONB) —
  metadata Json?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relaciones
  company_links      ContactoCompanyLink[]
  expedientes        Expediente[]
  direcciones        Direccion[]
  canales            CanalComunicacion[]
  relaciones_origen  Relacion[] @relation("RelacionOrigen")
  relaciones_destino Relacion[] @relation("RelacionDestino")
  carpetas           Carpeta[]

  @@unique([fiscal_id, fiscal_id_tipo]) /// Identifica única — NULL en fiscal_id excluido de la restricción
  @@index([status])
  @@index([es_cliente, es_precliente, es_facturadora]) /// Optimiza filtrado por roles en el Directorio
  @@map("contactos")
}

// ============================================================================
// ContactoCompanyLink  ←  TABLA PUENTE
//
// AQUÍ vive el company_id como separador lógico de tenant.
// Un mismo Contacto puede estar vinculado a "LX", a "LW", o a ambas.
// @@unique garantiza que no existan filas duplicadas por contacto + tenant.
// ============================================================================
model ContactoCompanyLink {
  id          String  @id @default(cuid())
  contacto_id String
  company_id  String  /// Tenant key dinámica: "LX", "LW", "LC"...
  role        String? /// Ej: "Cliente activo", "Contrario", "Proveedor", "Notario"

  created_at DateTime @default(now())

  contacto Contacto        @relation(fields: [contacto_id], references: [id])
  sociedad SociedadHolding @relation(fields: [company_id], references: [company_id])

  @@unique([contacto_id, company_id])
  @@map("contacto_company_links")
}

// ============================================================================
// Expediente  ←  UNIDAD MÍNIMA DE TRABAJO Y RENTABILIDAD
// ============================================================================
model Expediente {
  id          String  @id @default(cuid())
  company_id  String  /// Tenant key: "LX" | "LW" | cualquier futuro tenant
  codigo      String  @unique
  titulo      String
  descripcion String?

  // Semáforo Zero Leakage
  fuera_de_cuota       Boolean   @default(false)
  propuesta_firmada_at DateTime?

  status      String @default("ABIERTO")
  contacto_id String /// Cliente/Contacto principal del expediente

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  contacto Contacto        @relation(fields: [contacto_id], references: [id])
  sociedad SociedadHolding @relation(fields: [company_id], references: [company_id])

  @@index([company_id])
  @@index([status])
  @@map("expedientes")
}

// ============================================================================
// Direccion  ←  SATÉLITE 1:N de Contacto
//
// Permite múltiples direcciones por contacto (FISCAL, POSTAL, SEDE…).
// es_principal=true marca la dirección canónica para correspondencia.
// onDelete: Cascade — si el Contacto entra en flujo FORGOTTEN, las
// direcciones se eliminan junto a él (datos PII vinculados).
// ============================================================================
model Direccion {
  id         String  @id @default(cuid())
  contactoId String

  tipo           String  /// FISCAL | DOMICILIO_SOCIAL | WORKPLACE | OTRO
  etiqueta       String? /// Solo para WORKPLACE y OTRO: nombre personalizado (ej: "Obra M-40")
  calle          String
  calle_2        String? /// Complemento: piso, puerta, nave, oficina, etc.
  codigo_postal  String?
  ciudad         String?
  provincia      String?
  pais           String  @default("ES")
  es_principal   Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  contacto Contacto @relation(fields: [contactoId], references: [id], onDelete: Cascade)

  @@index([contactoId])
  @@map("direcciones")
}

// ============================================================================
// CanalComunicacion  ←  SATÉLITE 1:N de Contacto
//
// Permite múltiples canales por contacto: TELEFONO, EMAIL, WEB, LINKEDIN…
// etiqueta permite distinguir contextos ("Móvil Personal", "Email Facturación").
// es_principal=true marca el canal preferido para ese tipo.
// onDelete: Cascade — coherente con el ciclo de vida del Contacto.
// ============================================================================
model CanalComunicacion {
  id         String  @id @default(cuid())
  contactoId String

  tipo         String  /// TELEFONO | EMAIL | WEB | LINKEDIN | WHATSAPP | FAX | OTRA
  subtipo      String? /// Solo para TELEFONO: MOVIL | FIJO
  valor        String
  etiqueta     String? /// Ej: "Móvil Personal", "Email Facturación"
  es_principal Boolean @default(false)
  es_favorito  Boolean @default(false) /// true = teléfono favorito; se sincroniza en Contacto.telefono_movil/fijo

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  contacto Contacto @relation(fields: [contactoId], references: [id], onDelete: Cascade)

  @@index([contactoId])
  @@map("canales_comunicacion")
}

// ============================================================================
// TipoRelacion — Catálogo de tipos de relación entre Contactos
//
// GLOBAL — sin company_id. Catálogo de holding compartido entre LX y LW.
// Ejemplos: Socio, Administrador, Cónyuge, Contraparte, Contratista, Subcontratista.
// ============================================================================
model TipoRelacion {
  id          String  @id @default(cuid())
  nombre      String  @unique
  color       String  @default("#6b7280") /// Hex color para pills de UI
  categoria   String  /// Agrupación visual: "Societaria" | "Procesal" | "Laboral" | "Familiar" | "Otro"
  descripcion String?
  es_sistema  Boolean @default(false) /// true = predefinida (no editable ni borrable)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  relaciones Relacion[]

  @@index([categoria])
  @@map("tipos_relacion")
}

// ============================================================================
// Relacion — Relación directa entre dos Contactos
//
// GLOBAL — sin company_id. Coherente con Contacto siendo global.
// Arco dirigido (origen → destino). La UI muestra ambas direcciones.
// @@unique evita duplicados del mismo tipo para el mismo par.
// ============================================================================
model Relacion {
  id               String  @id @default(cuid())
  origen_id        String
  destino_id       String
  tipo_relacion_id String
  notas            String?

  /// Cargo o rol que el contacto origen tiene respecto al destino (ej: "Director Financiero")
  cargo                String?
  /// Departamento interno del contacto dentro de la organización destino
  departamento_interno String?
  /// ID de la Dirección (sede) vinculada a esta relación (FK lógica a Direccion.id)
  sede_vinculada_id    String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  origen        Contacto     @relation("RelacionOrigen",  fields: [origen_id],        references: [id])
  destino       Contacto     @relation("RelacionDestino", fields: [destino_id],        references: [id])
  tipo_relacion TipoRelacion @relation(fields: [tipo_relacion_id], references: [id])

  @@unique([origen_id, destino_id, tipo_relacion_id])
  @@index([origen_id])
  @@index([destino_id])
  @@map("relaciones")
}

// ============================================================================
// CategoriaEtiqueta — Agrupador del Sistema SALI de Etiquetas
//
// GLOBAL — sin company_id. Solo Admin puede crear/editar/borrar.
// Ejemplos: "Proceso", "Tipo Documento", "Departamento", "Financiera", "Procesal"
// ============================================================================
model CategoriaEtiqueta {
  id          String  @id @default(cuid())
  nombre      String  @unique
  descripcion String?
  orden       Int     @default(0) /// Ordenación manual en la UI de administración

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  etiquetas Etiqueta[]

  @@map("categorias_etiqueta")
}

// ============================================================================
// Etiqueta — Tag multidimensional del Sistema SALI
//
// GLOBAL — catálogo de holding. Solo Admin puede crear etiquetas.
// Etiquetas de sistema (es_sistema=true): Facturado, Pendiente, Blueprint, URGENTE
// Escalable: etiqueta Contactos, Expedientes, Documentos, Tareas.
// ============================================================================
model Etiqueta {
  id           String        @id @default(cuid())
  nombre       String
  color        String        @default("#6b7280") /// Hex color para pills de UI
  categoria_id String
  es_sistema   Boolean       @default(false)     /// true = predefinida, no eliminable
  activo       Boolean       @default(true)      /// false = archivada (soft-delete), oculta en catálogo pero preserva vínculos
  scope        EtiquetaScope @default(GLOBAL)    /// @Scope-Guard: visibilidad por tenant
  blueprint          Json?                             /// Estructura de subcarpetas para etiquetas Constructor (Servicio/Departamento)
  parent_id          String?                           /// Jerarquía: Servicio → Departamento padre (obligatorio para Servicio)
  es_expediente      Boolean       @default(false)     /// true = al asignar, abre modal de Nuevo Expediente
  solo_super_admin   Boolean       @default(false)     /// @Security-CISO: true = invisible para Staff en Drive, clonación y visor

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  categoria    CategoriaEtiqueta @relation(fields: [categoria_id], references: [id])
  parent       Etiqueta?         @relation("EtiquetaHierarchy", fields: [parent_id], references: [id])
  children     Etiqueta[]        @relation("EtiquetaHierarchy")
  asignaciones EtiquetaAsignada[]
  carpetas     Carpeta[]

  @@unique([nombre, categoria_id])
  @@index([categoria_id])
  @@index([parent_id])
  @@map("etiquetas")
}

// ============================================================================
// EtiquetaAsignada — Tabla polimórfica de asignación de etiquetas
//
// entidad_tipo: "CONTACTO" | "EXPEDIENTE" | "DOCUMENTO" | "TAREA"
// entidad_id:   CUID de la entidad referenciada.
//
// Sin FK polimórfica real (Prisma no soporta polimorfismo nativo).
// La integridad referencial la garantiza la capa de servicio.
// onDelete: Cascade — si se borra la etiqueta, se borran todas sus asignaciones.
// ============================================================================
model EtiquetaAsignada {
  id           String  @id @default(cuid())
  etiqueta_id  String
  entidad_id   String
  entidad_tipo String  /// "CONTACTO" | "EXPEDIENTE" | "DOCUMENTO" | "TAREA"
  asignado_por String? /// actor_id del usuario que asignó la etiqueta

  /// @Time-Keeper: timestamp de asignación (alias semántico de created_at)
  fecha_asignacion     DateTime  @default(now())
  /// @Time-Keeper: timestamp de desvinculación. null = etiqueta actualmente asignada
  fecha_desvinculacion DateTime?

  etiqueta Etiqueta @relation(fields: [etiqueta_id], references: [id], onDelete: Cascade)

  @@unique([etiqueta_id, entidad_id, entidad_tipo])
  @@index([entidad_id, entidad_tipo]) /// Consulta: "todas las etiquetas de este Expediente"
  @@index([etiqueta_id])             /// Consulta: "todas las entidades con esta etiqueta"
  @@map("etiquetas_asignadas")
}

// ============================================================================
// AuditLog  ←  REGISTRO INMUTABLE
//
// DISEÑO DELIBERADO:
//   - Sin @updatedAt (no se actualiza nunca)
//   - Sin relaciones FK (table_name + record_id son refs polimórficas en texto)
//   - La capa de repositorio prohíbe DELETE sobre esta tabla (sin excepción).
// ============================================================================
model AuditLog {
  id String @id @default(cuid())

  table_name String
  record_id  String
  action     AuditAction

  actor_id    String?
  actor_email String?
  ip_address  String?
  user_agent  String?

  old_data Json?
  new_data Json?
  notes    String?

  /// SHA-256(fiscal_id|fiscal_id_tipo) — solo en FORGET. Sin PII. Indexado para el Verificador de Borrado.
  hash_identificador String?
  /// Base legal del borrado: "RGPD Art.17 — Derecho al Olvido" / "Prescripción art.70 GILF"
  base_legal         String?
  /// Conteo de registros destruidos: { contactos, expedientes, facturas, documentos_drive }
  meta_counts        Json?
  /// true = este log puede ser purgado cuando se formalice el Derecho al Olvido completo
  purgeable          Boolean  @default(false)

  created_at DateTime @default(now())

  @@index([table_name, record_id])
  @@index([actor_id])
  @@index([created_at])
  @@index([hash_identificador])
  @@map("audit_logs")
}

// ============================================================================
// Carpeta — Nodo del árbol documental (Bóveda) del Contacto
//
// Dos tipos:
//   INTELIGENTE — vinculada a una Etiqueta Constructor (Departamento/Servicio).
//                 Se genera automáticamente al asignar la etiqueta al contacto.
//                 Sus subcarpetas de blueprint son inmutables (es_blueprint=true).
//   MANUAL      — creada libremente por el usuario. Sin vínculo a etiqueta.
//
// Jerarquía: self-referential (parent_id) para nesting ilimitado.
// ============================================================================
model Carpeta {
  id          String      @id @default(cuid())
  nombre      String
  tipo        CarpetaTipo @default(MANUAL)
  contacto_id String
  parent_id   String?                         /// Self-ref: subcarpeta de otra carpeta
  etiqueta_id String?                         /// Solo INTELIGENTE: FK a la Etiqueta Constructor origen
  es_blueprint Boolean    @default(false)     /// true = subcarpeta de blueprint, inmutable (no mover/renombrar/borrar)
  orden       Int         @default(0)         /// Ordenación manual dentro del mismo nivel

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  contacto Contacto  @relation(fields: [contacto_id], references: [id], onDelete: Cascade)
  parent   Carpeta?  @relation("CarpetaHierarchy", fields: [parent_id], references: [id])
  children Carpeta[] @relation("CarpetaHierarchy")
  etiqueta Etiqueta? @relation(fields: [etiqueta_id], references: [id])
  archivos Archivo[]

  @@index([contacto_id])
  @@index([parent_id])
  @@index([etiqueta_id])
  @@map("carpetas")
}

// ============================================================================
// Archivo — Referencia a un archivo dentro de una Carpeta
//
// Fase actual: metadatos locales. drive_file_id se vinculará en Fase 4+
// cuando se active la integración con Google Drive API.
// ============================================================================
model Archivo {
  id           String  @id @default(cuid())
  nombre       String
  carpeta_id   String
  mime_type    String?
  size_bytes   Int?                           /// Tamaño en bytes (informativo)
  drive_file_id String?                       /// Google Drive file ID (futuro)

  created_at DateTime @default(now())

  carpeta Carpeta @relation(fields: [carpeta_id], references: [id], onDelete: Cascade)

  @@index([carpeta_id])
  @@map("archivos")
}
