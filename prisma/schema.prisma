// ============================================================================
// schema.prisma — Brainlex / Lawork ERP
// Micro-Spec 1.1: Esquema Core y Multi-tenancy Híbrida
//
// Roles aplicados:
//   @Data-Architect  → modelo de Entidades único, lógica multitenant dinámica
//   @Security-CISO   → ciclo de vida Cuarentena, AuditLog inmutable
//
// VETO LEGAL (@security_and_legal.md):
//   NUNCA DELETE directo sobre un Contacto con historial comercial o legal.
//   Usar el flujo de Cuarentena: Auditoría → Bloqueo → Caducidad.
//
// REGLA DE VETO DE MIGRACIÓN:
//   Este archivo NO puede ejecutarse contra la BD hasta que el
//   Arquitecto Jefe dé autorización explícita.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

/// Tipo de contacto fiscal (persona física o jurídica).
enum ContactoTipo {
  PERSONA_FISICA
  PERSONA_JURIDICA
}

/// Ciclo de vida del Contacto — VETO LEGAL: no existe transición directa a DELETE.
///   ACTIVE     → registro operativo normal
///   QUARANTINE → baja lógica con retención legal (quarantine_reason OBLIGATORIO)
///   FORGOTTEN  → crypto-shredding GDPR: PII eliminado, NIF/Razón Social conservados
///                por obligación tributaria (art. 30 CComercio, Ley 58/2003 GILF)
enum ContactoStatus {
  ACTIVE
  QUARANTINE
  FORGOTTEN
}

/// Tipos de identificación fiscal aceptados.
enum FiscalIdTipo {
  NIF
  CIF
  NIE
  DNI
  PASAPORTE
  VAT
  TIE
  REGISTRO_EXTRANJERO
  CODIGO_SOPORTE
  SIN_REGISTRO
}

/// Tipo de teléfono para integraciones SMS/WhatsApp.
enum TipoTelefono {
  MOVIL
  FIJO
}

/// Acciones registradas en el AuditLog inmutable.
enum AuditAction {
  CREATE
  READ
  UPDATE
  QUARANTINE
  RESTORE
  FORGET
}

// ============================================================================
// SociedadHolding  ←  TABLA MAESTRA DEL HOLDING
//
// Cada fila representa una empresa del grupo.
// Escalabilidad REAL: añadir "Empresa C" = un INSERT en esta tabla.
// Sin tocar el esquema, sin migraciones de tipo, sin enum que evolucionar.
//
// company_id es una clave de tenant dinámica (String). Ejemplos: "LX", "LW", "LC".
// ============================================================================
model SociedadHolding {
  id          String  @id @default(cuid())
  company_id  String  @unique /// Clave de tenant dinámica: "LX", "LW", "LC"
  nombre      String
  nif         String?
  descripcion String?
  activa      Boolean @default(true)

  /// Meses de retención en cuarentena para esta Sociedad.
  /// Por defecto: 48 meses (4 años fiscal — art. 30 CComercio, Ley 58/2003 GILF).
  quarantine_months Int @default(48)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relaciones descendentes
  contacto_links ContactoCompanyLink[]
  expedientes    Expediente[]

  @@map("sociedades_holding")
}

// ============================================================================
// Contacto  ←  TABLA GLOBAL (deliberadamente sin company_id)
//
// Unifica Contactos y Clientes para evitar duplicidades entre LX y LW.
// Un mismo contacto puede tener actividad en LX, en LW, o en ambas.
//
// La vinculación empresa ↔ contacto se gestiona mediante ContactoCompanyLink.
// El company_id vive en la tabla puente, NO aquí.
// ============================================================================
model Contacto {
  id   String       @id @default(cuid())
  tipo ContactoTipo @default(PERSONA_FISICA)

  // — Persona Física —
  nombre    String?
  apellido1 String?
  apellido2 String?

  // — Persona Jurídica —
  razon_social  String?
  tipo_sociedad String? /// S.L., S.A., S.L.U., etc. — requerido si tipo = PERSONA_JURIDICA

  // — Identificación Fiscal —
  fiscal_id      String?
  fiscal_id_tipo FiscalIdTipo?

  // — Datos de contacto —
  email          String?      @unique /// NULL no viola @unique (PostgreSQL) → varios contactos sin email son válidos
  telefono       String?
  tipo_telefono  TipoTelefono @default(MOVIL)

  // — Roles (no excluyentes) —
  es_cliente  Boolean @default(false)
  es_contacto Boolean @default(true)

  // — Ciclo de vida (VETO LEGAL) ————————————————————————————————————————————
  // REGLA: si status = QUARANTINE → quarantine_reason OBLIGATORIO
  //        La capa de servicio lanza 403 si se intenta DELETE con historial.
  //        Si status = FORGOTTEN  → PII borrado, pero NIF/razon_social intactos.
  status                ContactoStatus @default(ACTIVE)
  quarantine_reason     String?   /// Requerido cuando status = QUARANTINE
  quarantine_expires_at DateTime? /// Plazo asignado por Agente Legal
  forgotten_at          DateTime? /// Timestamp del crypto-shredding GDPR

  // — Notas libres —
  notas String?

  // — Metadatos extendidos (JSONB) —
  metadata Json?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relaciones
  company_links ContactoCompanyLink[]
  expedientes   Expediente[]

  @@unique([fiscal_id, fiscal_id_tipo]) /// Identifica única — NULL en fiscal_id excluido de la restricción
  @@index([status])
  @@map("contactos")
}

// ============================================================================
// ContactoCompanyLink  ←  TABLA PUENTE
//
// AQUÍ vive el company_id como separador lógico de tenant.
// Un mismo Contacto puede estar vinculado a "LX", a "LW", o a ambas.
// @@unique garantiza que no existan filas duplicadas por contacto + tenant.
// ============================================================================
model ContactoCompanyLink {
  id          String  @id @default(cuid())
  contacto_id String
  company_id  String  /// Tenant key dinámica: "LX", "LW", "LC"...
  role        String? /// Ej: "Cliente activo", "Contrario", "Proveedor", "Notario"

  created_at DateTime @default(now())

  contacto Contacto        @relation(fields: [contacto_id], references: [id])
  sociedad SociedadHolding @relation(fields: [company_id], references: [company_id])

  @@unique([contacto_id, company_id])
  @@map("contacto_company_links")
}

// ============================================================================
// Expediente  ←  UNIDAD MÍNIMA DE TRABAJO Y RENTABILIDAD
// ============================================================================
model Expediente {
  id          String  @id @default(cuid())
  company_id  String  /// Tenant key: "LX" | "LW" | cualquier futuro tenant
  codigo      String  @unique
  titulo      String
  descripcion String?

  // Semáforo Zero Leakage
  fuera_de_cuota       Boolean   @default(false)
  propuesta_firmada_at DateTime?

  status      String @default("ABIERTO")
  contacto_id String /// Cliente/Contacto principal del expediente

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  contacto Contacto        @relation(fields: [contacto_id], references: [id])
  sociedad SociedadHolding @relation(fields: [company_id], references: [company_id])

  @@index([company_id])
  @@index([status])
  @@map("expedientes")
}

// ============================================================================
// AuditLog  ←  REGISTRO INMUTABLE
//
// DISEÑO DELIBERADO:
//   - Sin @updatedAt (no se actualiza nunca)
//   - Sin relaciones FK (table_name + record_id son refs polimórficas en texto)
//   - La capa de repositorio prohíbe DELETE sobre esta tabla (sin excepción).
// ============================================================================
model AuditLog {
  id String @id @default(cuid())

  table_name String
  record_id  String
  action     AuditAction

  actor_id    String?
  actor_email String?
  ip_address  String?
  user_agent  String?

  old_data Json?
  new_data Json?
  notes    String?

  created_at DateTime @default(now())

  @@index([table_name, record_id])
  @@index([actor_id])
  @@index([created_at])
  @@map("audit_logs")
}
